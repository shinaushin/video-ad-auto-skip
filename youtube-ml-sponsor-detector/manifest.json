{
  "manifest_version": 3,
  "name": "YouTube ML Sponsor Detector",
  "version": "1.0.0",
  "description": "Detects in-video sponsor segments using a bimodal ML model (keyword feature vector + MFCC audio). Experimental — runs alongside or instead of the Sponsor Speeder.",
  "permissions": [],
  "host_permissions": [
    "https://*.run.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "ort.min.js",
        "ort-env.js",
        "feature-extractor.js",
        "ml-detector.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["model.onnx", "ort.min.js", "ort-wasm-simd.wasm", "ort-wasm.wasm"],
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"]
    }
  ]
}
